d like to change your store visibility, go to WooCommerce > Settings > Site visibility.":["\u0421\u043f\u0440\u0435\u043c\u043d\u0438 \u0437\u0430 \u043f\u043e\u0447\u0435\u0442\u0430\u043a \u043f\u0440\u043e\u0434\u0430\u0458\u0435? \u041f\u0440\u0435 \u043d\u0435\u0433\u043e \u0448\u0442\u043e \u043f\u043e\u043a\u0440\u0435\u043d\u0435\u0442\u0435 \u0441\u0432\u043e\u0458\u0443 \u043f\u0440\u043e\u0434\u0430\u0432\u043d\u0438\u0446\u0443, \u0443\u0432\u0435\u0440\u0438\u0442\u0435 \u0441\u0435 \u0434\u0430 \u0441\u0442\u0435 \u0438\u0437\u0432\u0440\u0448\u0438\u043b\u0438 \u043e\u0432\u0435 \u043e\u0441\u043d\u043e\u0432\u043d\u0435 \u0437\u0430\u0434\u0430\u0442\u043a\u0435. \u0410\u043a\u043e \u0436\u0435\u043b\u0438\u0442\u0435 \u0434\u0430 \u043f\u0440\u043e\u043c\u0435\u043d\u0438\u0442\u0435 \u0432\u0438\u0434\u0459\u0438\u0432\u043e\u0441\u0442 \u043f\u0440\u043e\u0434\u0430\u0432\u043d\u0438\u0446\u0435, \u0438\u0434\u0438\u0442\u0435 \u043d\u0430 WooCommerce > \u041f\u043e\u0434\u0435\u0448\u0430\u0432\u0430\u045a\u0430 > \u0412\u0438\u0434\u0459\u0438\u0432\u043e\u0441\u0442 \u0441\u0430\u0458\u0442\u0430."],"What\u2019s next?":["\u0428\u0442\u0430 \u0458\u0435 \u0441\u043b\u0435\u0434\u0435\u045b\u0435?"],"Launch Your Store":["\u041f\u043e\u043a\u0440\u0435\u043d\u0438\u0442\u0435 \u0441\u0432\u043e\u0458\u0443 \u043f\u0440\u043e\u0434\u0430\u0432\u043d\u0438\u0446\u0443"],"Launch your store":["\u041f\u043e\u043a\u0440\u0435\u043d\u0438\u0442\u0435 \u0441\u0432\u043e\u0458\u0443 \u043f\u0440\u043e\u0434\u0430\u0432\u043d\u0438\u0446\u0443"],"Set up %s":["\u041f\u043e\u0434\u0435\u0441\u0438 %s"],"Please try again":["\u041c\u043e\u043b\u0438\u043c \u0432\u0430\u0441, \u043f\u043e\u043a\u0443\u0448\u0430\u0458\u0442\u0435 \u043f\u043e\u043d\u043e\u0432\u043e"],"Back to Home":["\u041d\u0430\u0442\u0440\u0430\u0433 \u043d\u0430 \u043f\u043e\u0447\u0435\u0442\u043d\u0443 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443"],"Use left and right arrow keys to resize the canvas. Hold shift to resize in larger increments.":["\u041a\u043e\u0440\u0438\u0441\u0442\u0438\u0442\u0435 \u043b\u0435\u0432\u0443 \u0438 \u0434\u0435\u0441\u043d\u0443 \u0441\u0442\u0440\u0435\u043b\u0438\u0446\u0443 \u043d\u0430 \u0442\u0430\u0441\u0442\u0430\u0442\u0443\u0440\u0438 \u0437\u0430 \u043f\u0440\u043e\u043c\u0435\u043d\u0443 \u0432\u0435\u043b\u0438\u0447\u0438\u043d\u0435 \u043f\u043b\u0430\u0442\u043d\u0430. \u0414\u0440\u0436\u0438\u0442\u0435 \u201eShift\u201c \u0442\u0430\u0441\u0442\u0435\u0440 \u0437\u0430 \u043f\u0440\u043e\u043c\u0435\u043d\u0443 \u0432\u0435\u043b\u0438\u0447\u0438\u043d\u0435 \u0443 \u0432\u0435\u045b\u0438\u043c \u0438\u043d\u043a\u0440\u0435\u043c\u0435\u043d\u0442\u0438\u043c\u0430."],"Drag to resize":["\u041f\u0440\u0435\u0432\u0443\u0446\u0438 \u0437\u0430 \u043f\u0440\u043e\u043c\u0435\u043d\u0443 \u0432\u0435\u043b\u0438\u0447\u0438\u043d\u0435"],"Go back":["\u0418\u0434\u0438 \u043d\u0430\u0437\u0430\u0434"],"We appreciate your feedback!":["\u0426\u0435\u043d\u0438\u043c\u043e \u0432\u0430\u0448\u0435 \u043f\u043e\u0432\u0440\u0430\u0442\u043d\u0435 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u0458\u0435!"],"Send":["\u041f\u043e\u0448\u0430\u0459\u0438"],"Back":["\u041d\u0430\u0437\u0430\u0434"],"Install":["\u0418\u043d\u0441\u0442\u0430\u043b\u0438\u0440\u0430\u0458"],"Install %s":["\u041f\u043e\u0441\u0442\u0430\u0432\u0438 %s"],"Copy link":["\u041a\u043e\u043f\u0438\u0440\u0430\u0458 \u0432\u0435\u0437\u0443"],"Enable":["\u0423\u043a\u0459\u0443\u0447\u0438"],"Copied!":["\u041a\u043e\u043f\u0438\u0440\u0430\u043d\u043e!"],"Close":["\u0417\u0430\u0442\u0432\u043e\u0440\u0438"],"Preview":["\u041f\u0440\u0435\u0433\u043b\u0435\u0434\u0430\u0458"],"Cancel":["\u041e\u0442\u043a\u0430\u0436\u0438"],"Metro Manila":["\u041c\u0435\u0442\u0440\u043e \u041c\u0430\u043d\u0438\u043b\u0430"],"Roma":["\u0420\u0438\u043c"]}},"comment":{"reference":"assets\/client\/admin\/chunks\/launch-store.js"}}